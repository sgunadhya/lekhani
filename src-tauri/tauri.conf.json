{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lekhani",
  "version": "0.1.0",
  "identifier": "dev.lekhani",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "cd frontend && env NO_COLOR=true trunk serve --port 3000 --open false",
    "beforeBuildCommand": "cd frontend && env NO_COLOR=true trunk build --release"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Lekhani",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "app",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
